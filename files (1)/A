import { TestBed, fakeAsync, tick, discardPeriodicTasks } from '@angular/core/testing';
import { Router } from '@angular/router';
 
import { ReportImageStore, ReportImageStoreType } from './report-image.store';
import { ImageApiService } from './image-api.service';
import { StorageService } from './storage.service';
import { asyncData, asyncError } from '../../testing/test-utils';
 
const TIME_TO_LIVE_MS = 1000 * 60 * 60 * 5;
const CLEANUP_INTERVAL_MS = 1000 * 30;
 
describe('ReportImageStore', () => {
    let store: ReportImageStoreType;
    let imageService: jest.Mocked<ImageApiService>;
    let storageService: jest.Mocked<StorageService>;
 
    let createObjectURLMock: jest.Mock;
    let revokeObjectURLMock: jest.Mock;
    let canParseMock: jest.Mock;
    let dateNowMock: jest.Mock;
 
    const originalDateNow = Date.now;
 
    let fileReaderMock: {
        onload: (() => void) | null;
        result: string;
        readAsDataURL: jest.Mock;
    };
 
    beforeEach(() => {
        dateNowMock = jest.fn().mockReturnValue(0);
        Date.now = dateNowMock;
 
        createObjectURLMock = jest.fn().mockReturnValue('blob:http://localhost/mock-uuid');
        revokeObjectURLMock = jest.fn();
        canParseMock = jest.fn().mockReturnValue(false);
 
        Object.defineProperty(URL, 'createObjectURL', { value: createObjectURLMock, configurable: true });
        Object.defineProperty(URL, 'revokeObjectURL', { value: revokeObjectURLMock, configurable: true });
        Object.defineProperty(URL, 'canParse', { value: canParseMock, configurable: true });
 
        fileReaderMock = {
            onload: null,
            result: '',
            readAsDataURL: jest.fn().mockImplementation(() => {
                fileReaderMock.result = 'data:image/png;base64,abc123';
                fileReaderMock.onload?.();
            }),
        };
        Object.defineProperty(global, 'FileReader', {
            value: jest.fn(() => fileReaderMock),
            writable: true,
            configurable: true,
        });
 
        imageService = {} as jest.Mocked<ImageApiService>;
        imageService.getReportImage = jest.fn();
 
        storageService = {} as jest.Mocked<StorageService>;
        storageService.getItem = jest.fn().mockReturnValue(null);
        storageService.setItem = jest.fn();
        storageService.getandremoveitem = jest.fn();
 
        TestBed.configureTestingModule({
            providers: [
                { provide: ImageApiService, useValue: imageService },
                { provide: StorageService, useValue: storageService },
                { provide: Router, useValue: { url: '/reports' } },
            ],
        });
 
        store = TestBed.inject(ReportImageStore);
    });
 
    afterEach(() => {
        Date.now = originalDateNow;
    });
 
    describe('getUrl', () => {
        it('should return undefined when no cache and no storage exist', fakeAsync(() => {
            // arrange
            storageService.getItem.mockReturnValue(null);
 
            // act
            const result = store.getUrl(1);
 
            // assert
            expect(result).toBeUndefined();
            discardPeriodicTasks();
        }));
 
        it('should return url from storage when it is a valid data URL', fakeAsync(() => {
            // arrange
            const dataUrl = 'data:image/png;base64,abc123';
            storageService.getItem.mockReturnValue(dataUrl);
            canParseMock.mockReturnValue(true);
 
            // act
            const result = store.getUrl(1);
 
            // assert
            expect(result).toBe(dataUrl);
            expect(store.entityMap()[1]?.url).toBe(dataUrl);
            discardPeriodicTasks();
        }));
 
        it('should return undefined when storage contains bare base64', fakeAsync(() => {
            // arrange
            storageService.getItem.mockReturnValue('iVBORw0KGgoAAAA');
            canParseMock.mockReturnValue(false);
 
            // act
            const result = store.getUrl(1);
 
            // assert
            expect(result).toBeUndefined();
            expect(store.entityMap()[1]).toBeUndefined();
            discardPeriodicTasks();
        }));
 
        it('should serve from entity cache without hitting storage on subsequent calls', fakeAsync(() => {
            // arrange
            storageService.getItem.mockReturnValue('data:image/png;base64,abc123');
            canParseMock.mockReturnValue(true);
            store.getUrl(1);
            storageService.getItem.mockClear();
 
            // act
            const result = store.getUrl(1);
 
            // assert
            expect(result).toBe('data:image/png;base64,abc123');
            expect(storageService.getItem).not.toHaveBeenCalled();
            discardPeriodicTasks();
        }));
 
        it('should refresh lastAccessedAt on cache hit', fakeAsync(() => {
            // arrange
            dateNowMock.mockReturnValue(1000);
            storageService.getItem.mockReturnValue('data:image/png;base64,abc123');
            canParseMock.mockReturnValue(true);
            store.getUrl(1);
            expect(store.entityMap()[1]?.lastAccessedAt).toBe(1000);
 
            // act
            dateNowMock.mockReturnValue(6000);
            store.getUrl(1);
 
            // assert
            expect(store.entityMap()[1]?.lastAccessedAt).toBe(6000);
            discardPeriodicTasks();
        }));
    });
 
    describe('loadUrl', () => {
        const blob = new Blob(['test'], { type: 'image/png' });
 
        it('should create object URL from API blob and emit it', fakeAsync(() => {
            // arrange
            imageService.getReportImage.mockReturnValue(asyncData(blob));
            createObjectURLMock.mockReturnValue('blob:http://localhost/abc');
            let emittedUrl = '';
 
            // act
            store.loadUrl(1).subscribe((url) => (emittedUrl = url));
            tick();
 
            // assert
            expect(createObjectURLMock).toHaveBeenCalledWith(blob);
            expect(emittedUrl).toBe('blob:http://localhost/abc');
            discardPeriodicTasks();
        }));
 
        it('should update entity state after successful load', fakeAsync(() => {
            // arrange
            dateNowMock.mockReturnValue(5000);
            imageService.getReportImage.mockReturnValue(asyncData(blob));
            createObjectURLMock.mockReturnValue('blob:http://localhost/abc');
 
            // act
            store.loadUrl(1).subscribe();
            tick();
 
            // assert
            const entity = store.entityMap()[1];
            expect(entity?.url).toBe('blob:http://localhost/abc');
            expect(entity?.lastAccessedAt).toBe(5000);
            discardPeriodicTasks();
        }));
 
        it('should persist blob as data URL to session storage', fakeAsync(() => {
            // arrange
            imageService.getReportImage.mockReturnValue(asyncData(blob));
 
            // act
            store.loadUrl(1).subscribe();
            tick();
 
            // assert
            expect(storageService.setItem).toHaveBeenCalledWith(
                '1',
                'data:image/png;base64,abc123',
                'SESSION',
            );
            discardPeriodicTasks();
        }));
 
        it('should extract page name from router URL', fakeAsync(() => {
            // arrange
            imageService.getReportImage.mockReturnValue(asyncData(blob));
 
            // act
            store.loadUrl(42).subscribe();
            tick();
 
            // assert
            expect(imageService.getReportImage).toHaveBeenCalledWith(42, 'reports');
            discardPeriodicTasks();
        }));
 
        it('should propagate API errors to subscriber', fakeAsync(() => {
            // arrange
            const error = new Error('Network failure');
            imageService.getReportImage.mockReturnValue(asyncError(error));
            let caughtError: Error | undefined;
 
            // act
            store.loadUrl(1).subscribe({ error: (err) => (caughtError = err) });
            tick();
 
            // assert
            expect(caughtError).toBe(error);
            expect(store.entities()).toHaveLength(0);
            discardPeriodicTasks();
        }));
    });
 
    describe('removeUrl', () => {
        it('should revoke object URL, remove entity, and clear storage', fakeAsync(() => {
            // arrange
            const blob = new Blob(['test'], { type: 'image/png' });
            imageService.getReportImage.mockReturnValue(asyncData(blob));
            createObjectURLMock.mockReturnValue('blob:http://localhost/abc');
            store.loadUrl(1).subscribe();
            tick();
 
            // act
            store.removeUrl(1);
 
            // assert
            expect(revokeObjectURLMock).toHaveBeenCalledWith('blob:http://localhost/abc');
            expect(store.entityMap()[1]).toBeUndefined();
            expect(storageService.getandremoveitem).toHaveBeenCalledWith('1', 'SESSION');
            discardPeriodicTasks();
        }));
 
        it('should clear storage even when no entity exists', fakeAsync(() => {
            // arrange — no entity for id 999
 
            // act
            store.removeUrl(999);
 
            // assert
            expect(revokeObjectURLMock).not.toHaveBeenCalled();
            expect(storageService.getandremoveitem).toHaveBeenCalledWith('999', 'SESSION');
            discardPeriodicTasks();
        }));
    });
 
    describe('cleanup', () => {
        it('should remove expired entities and revoke their URLs', fakeAsync(() => {
            // arrange — entity created at time 0
            const blob = new Blob(['test'], { type: 'image/png' });
            imageService.getReportImage.mockReturnValue(asyncData(blob));
            createObjectURLMock.mockReturnValue('blob:http://localhost/abc');
            store.loadUrl(1).subscribe();
            tick();
 
            // act — advance Date.now past TTL, trigger one cleanup
            dateNowMock.mockReturnValue(TIME_TO_LIVE_MS + 1);
            tick(CLEANUP_INTERVAL_MS);
 
            // assert
            expect(store.entities()).toHaveLength(0);
            expect(revokeObjectURLMock).toHaveBeenCalledWith('blob:http://localhost/abc');
            discardPeriodicTasks();
        }));
 
        it('should keep non-expired entities', fakeAsync(() => {
            // arrange — entity created at time 0
            const blob = new Blob(['test'], { type: 'image/png' });
            imageService.getReportImage.mockReturnValue(asyncData(blob));
            createObjectURLMock.mockReturnValue('blob:http://localhost/abc');
            store.loadUrl(1).subscribe();
            tick();
            revokeObjectURLMock.mockClear();
 
            // act — Date.now within TTL, trigger cleanup
            dateNowMock.mockReturnValue(TIME_TO_LIVE_MS - 1);
            tick(CLEANUP_INTERVAL_MS);
 
            // assert
            expect(store.entities()).toHaveLength(1);
            expect(revokeObjectURLMock).not.toHaveBeenCalled();
            discardPeriodicTasks();
        }));
    });
});
