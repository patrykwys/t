@Component({
  template: `<div *featureFlag="flagKey">Visible Content</div>`,
  imports: [FeatureFlagDirective],
})
class HostComponent {
  flagKey = 'test-flag';
}

describe('FeatureFlagDirective', () => {
  let fixture: ComponentFixture<HostComponent>;
  const flagSignals = new Map<string, WritableSignal<boolean>>();

  function mockGetFlag(key: string, defaultValue = false): Signal<boolean> {
    const existing = flagSignals.get(key);
    if (existing) return existing.asReadonly();

    const s = signal(defaultValue);
    flagSignals.set(key, s);
    return s.asReadonly();
  }

  function textContent(): string {
    return (fixture.nativeElement as HTMLElement).textContent!.trim();
  }

  beforeEach(async () => {
    flagSignals.clear();

    await TestBed.configureTestingModule({
      imports: [HostComponent],
      providers: [
        { provide: FeatureFlagService, useValue: { getFlag: mockGetFlag } },
      ],
    }).compileComponents();

    fixture = TestBed.createComponent(HostComponent);
  });

  it('should hide content when flag is disabled', () => {
    // act
    fixture.detectChanges();

    // assert
    expect(textContent()).toBe('');
  });

  it('should show content when flag is enabled', () => {
    // arrange
    mockGetFlag('test-flag');
    flagSignals.get('test-flag')!.set(true);

    // act
    fixture.detectChanges();

    // assert
    expect(textContent()).toBe('Visible Content');
  });

  it('should show content when flag changes from disabled to enabled', () => {
    // arrange
    fixture.detectChanges();
    expect(textContent()).toBe('');

    // act
    flagSignals.get('test-flag')!.set(true);
    fixture.detectChanges();

    // assert
    expect(textContent()).toBe('Visible Content');
  });

  it('should hide content when flag changes from enabled to disabled', () => {
    // arrange
    mockGetFlag('test-flag');
    flagSignals.get('test-flag')!.set(true);
    fixture.detectChanges();
    expect(textContent()).toBe('Visible Content');

    // act
    flagSignals.get('test-flag')!.set(false);
    fixture.detectChanges();

    // assert
    expect(textContent()).toBe('');
  });

  it('should re-evaluate when the flag key changes', () => {
    // arrange
    mockGetFlag('flag-a');
    mockGetFlag('flag-b');
    flagSignals.get('flag-a')!.set(false);
    flagSignals.get('flag-b')!.set(true);
    fixture.detectChanges();
    expect(textContent()).toBe('');

    // act
    fixture.componentInstance.flagKey = 'flag-b';
    fixture.detectChanges();

    // assert
    expect(textContent()).toBe('Visible Content');
  });
});
