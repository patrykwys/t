.data-sensitivity {
  display: flex;
  align-items: center;
  gap: 8px;
}

.data-sensitivity__label {
  font-weight: 600;
  margin-right: 8px;
}

.data-sensitivity__action-btn {
  color: #6b7280;
}

.data-sensitivity__select {
  width: 200px;
}

.pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 14px;
  border-radius: 9999px;
  border: none;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.5;
  transition: opacity 0.15s ease;
}

.pill:hover {
  opacity: 0.85;
}

.pill__icon {
  font-size: 16px;
  width: 16px;
  height: 16px;
}

.pill[data-level='public'] {
  background-color: #dbeafe;
  color: #1e40af;
}

.pill[data-level='internal'] {
  background-color: #dcfce7;
  color: #166534;
}

.pill[data-level='confidential'] {
  background-color: #fef9c3;
  color: #854d0e;
}

.pill[data-level='highly-confidential'] {
  background-color: #fee2e2;
  color: #991b1b;
}

.pill[data-level='none'] {
  background-color: #f3f4f6;
  color: #4b5563;
}

.info-popover {
  padding: 24px;
  max-width: 420px;
}

.info-popover__title {
  font-size: 16px;
  font-weight: 600;
  margin: 0 0 16px;
}

.info-popover__levels {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 16px;
}

.info-popover__level {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.info-popover__level p {
  margin: 4px 0 0;
  font-size: 13px;
  line-height: 1.5;
  color: #6b7280;
}

.info-popover__dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4px;
}

.info-popover__level[data-level='public'] .info-popover__dot {
  background-color: #3b82f6;
}

.info-popover__level[data-level='internal'] .info-popover__dot {
  background-color: #22c55e;
}

.info-popover__level[data-level='confidential'] .info-popover__dot {
  background-color: #f59e0b;
}

.info-popover__level[data-level='highly-confidential'] .info-popover__dot {
  background-color: #ef4444;
}

.info-popover__footer {
  font-size: 13px;
  line-height: 1.5;
  margin: 16px 0 8px;
  color: #6b7280;
}

.info-popover__link {
  color: #2563eb;
  text-decoration: underline;
}

.info-popover__note {
  font-size: 13px;
  color: #6b7280;
  margin: 0;
}



@Component({
  selector: 'app-data-sensitivity',
  standalone: true,
  imports: [
    MatIconModule,
    MatButtonModule,
    MatMenuModule,
    MatSelectModule,
  ],
  templateUrl: './data-sensitivity.component.html',
  styleUrl: './data-sensitivity.component.scss',
})
export class DataSensitivityComponent {


  onSave(): void {
    if (this.isSameAsOriginal()) {
      this.cancelEdit();
      return;
    }


  }
}


  <button mat-icon-button class="data-sensitivity__action-btn" [matMenuTriggerFor]="infoMenu" type="button">
    <mat-icon>info_outline</mat-icon>
  </button>

  <mat-menu #infoMenu="matMenu" class="info-popover-panel">
