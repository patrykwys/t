        For full details, refer to the
        <a href="#" class="info-popover__link">xxxxxxxxxxxxxxxxx.</a>.
        For a quick reference, refer to the
        <a href="#" class="info-popover__link">xxxxxxxxxxxxxxxxx.</a>.
      </p>

      <p class="info-popover__note">
        <em>xxxxxxxxxxxxxxxxx.</em>
      </p>
    </div>
  </mat-menu>



class MockDialogRef {
  constructor(private readonly result: string) {}
  afterClosed = () => of(this.result);
}

class MockMatDialog {
  nextResult = 'no';

  open(): MockDialogRef {
    return new MockDialogRef(this.nextResult);
  }
}

describe('DataSensitivityComponent', () => {
  let fixture: ComponentFixture<DataSensitivityComponent>;
  let component: DataSensitivityComponent;
  let mockDialog: MockMatDialog;

  beforeEach(() => {
    mockDialog = new MockMatDialog();

    TestBed.configureTestingModule({
      imports: [
        DataSensitivityComponent,
        MatIconModule,
        MatButtonModule,
        MatDialogModule,
        NoopAnimationsModule,
      ],
      providers: [
        { provide: MatDialog, useValue: mockDialog },
      ],
    });

    fixture = TestBed.createComponent(DataSensitivityComponent);
    component = fixture.componentInstance;
    fixture.componentRef.setInput('value', 'Public');
    fixture.detectChanges();
  });

  describe('enterEdit', () => {
    it('should set editing to true and sync selectedClassification to current value', () => {
      // Act
      component.enterEdit();

      // Assert
      expect(component.editing()).toBe(true);
      expect(component.selectedClassification()).toBe('Public');
    });
  });

  describe('cancelEdit', () => {
    it('should set editing to false', () => {
      // Arrange
      component.enterEdit();

      // Act
      component.cancelEdit();

      // Assert
      expect(component.editing()).toBe(false);
    });
  });

  describe('pillLabel', () => {
    it.each([
      ['Public', 'Public'],
      ['Internal', 'Internal'],
      ['Confidential', 'Confidential'],
      ['Highly Confidential', 'Highly Confidential'],
      ['Non-Business', 'Non-Business'],
      ['Not-Set', 'Not Specified'],
    ] as [Sp2iDataCertification, string][])('should return "%s" label as "%s"', (input, expected) => {
      // Arrange
      fixture.componentRef.setInput('value', input);
      fixture.detectChanges();

      // Act & Assert
      expect(component.pillLabel()).toBe(expected);
    });
  });

  describe('pillLevel', () => {
    it.each([
      ['Public', 'public'],
      ['Internal', 'internal'],
      ['Confidential', 'confidential'],
      ['Highly Confidential', 'highly-confidential'],
      ['Non-Business', 'none'],
      ['Not-Set', 'none'],
    ] as [Sp2iDataCertification, string][])('should return "%s" level as "%s"', (input, expected) => {
      // Arrange
      fixture.componentRef.setInput('value', input);
      fixture.detectChanges();

      // Act & Assert
      expect(component.pillLevel()).toBe(expected);
    });
  });

  describe('isSameAsOriginal', () => {
    it('should return true when selectedClassification matches value', () => {
      // Arrange
      component.selectedClassification.set('Public');

      // Act & Assert
      expect(component.isSameAsOriginal()).toBe(true);
    });

    it('should return false when selectedClassification differs from value', () => {
      // Arrange
      component.selectedClassification.set('Confidential');

      // Act & Assert
      expect(component.isSameAsOriginal()).toBe(false);
    });
  });

  describe('onSave', () => {
    it('should cancel editing without opening dialog when value is unchanged', () => {
      // Arrange
      component.enterEdit();

      // Act
      component.onSave();

      // Assert
      expect(component.editing()).toBe(false);
    });

    it('should emit confirmed and close editing when dialog confirms', () => {
      // Arrange
      let emittedValue: Sp2iDataCertification | null = null;
      component.confirmed.subscribe((value) => emittedValue = value);
      component.enterEdit();
      component.selectedClassification.set('Confidential');
      mockDialog.nextResult = 'yes';

      // Act
      component.onSave();

      // Assert
      expect(emittedValue).toBe('Confidential');
      expect(component.editing()).toBe(false);
    });

    it('should not emit and keep editing open when dialog rejects', () => {
      // Arrange
      let emittedValue: Sp2iDataCertification | null = null;
      component.confirmed.subscribe((value) => emittedValue = value);
      component.enterEdit();
      component.selectedClassification.set('Confidential');
      mockDialog.nextResult = 'no';

      // Act
      component.onSave();

      // Assert
      expect(emittedValue).toBeNull();
      expect(component.editing()).toBe(true);
    });
  });
});


describe('ParentComponent', () => {
  let fixture: ComponentFixture<ParentComponent>;
  let component: ParentComponent;
  let mockStore: jest.Mocked<DatasourceStore>;

  beforeEach(() => {
    mockStore = {
      datasources: createMockSignalWithValue([]),
      updateDatasource: jest.fn(),
    } as jest.Mocked<DatasourceStore>;

    TestBed.configureTestingModule({
      imports: [ParentComponent],
      providers: [
        { provide: DatasourceStore, useValue: mockStore },
      ],
    });

    fixture = TestBed.createComponent(ParentComponent);
    component = fixture.componentInstance;
  });

  describe('onCertificationChanged', () => {
    it('should call store.updateDatasource with correct id and value', () => {
      // Arrange
      fixture.componentRef.setInput('datasource', MOCK_DATASOURCE);
      fixture.detectChanges();

      // Act
      component.onCertificationChanged('Confidential');

      // Assert
      expect(mockStore.updateDatasource).toHaveBeenCalledWith({
        id: 'ds-1',
        request: 'Confidential',
      });
    });

    it('should not call store when datasource is undefined', () => {
      // Act
      component.onCertificationChanged('Internal');

      // Assert
      expect(mockStore.updateDatasource).not.toHaveBeenCalled();
    });
  });
});
